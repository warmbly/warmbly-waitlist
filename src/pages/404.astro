---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header/Header.astro';
import Heropic from '../components/Heropic.astro';
import Box from '../components/Section2/Box.astro';
import Icon from '../components/Section2/Icon.astro';
import BoxTop from '../components/Section2/BoxTop.astro';
import BoxStep from '../components/Section2/BoxStep.astro';
import BoxTitle from "../components/Section2/BoxTitle.astro";
import BoxDescription from "../components/Section2/BoxDescription.astro";
import Footer from "../components/Footer/Footer.astro";

const title = "404 Not Found"
const description = "The page you’re looking for doesn’t seem to exist. Head back to Warmbly and find the right solution for your needs."
---

<Layout {title} {description}>
	<Header/>
	<div class="px-4 bg-gray-50 overflow-hidden">
		<div class="max-w-7xl mx-auto">
			<div class="flex flex-col items-center">
				<div class="py-2 px-3 mt-20 text-gray-500"><span class="bg-linear-to-r from-cyan-500 to-blue-600 text-white py-1 px-3 rounded-lg mr-3">AI</span> Powered Personalization</div>
				<h1 class="font-bold text-5xl text-center text-gray-800 mb-13 max-w-5xl mt-10 leading-13">404: Page Not Found</h1>
				<p class="text-center max-w-6xl text-gray-500 text-md">Warmbly makes it easy to launch cold email campaigns that feel truly personal and human. Build trust, save time and create meaningful connections with AI that works for you — so you can focus on nurturing relationships and growing your business.</p>
			</div>
			<div class="mt-15 flex justify-center gap-7">
				<a href="https://app.warmbly.com/" class="px-5 py-3 bg-blue-500 transition hover:bg-blue-600 text-gray-50 rounded-full">Get started for free</a>
				<a href="/" class="border-3 flex items-center text-blue-700 border-blue-500 px-5 transition hover:brightness-80 rounded-full">Go to Home</a>
			</div>
			<Heropic className="w-full mt-20 shadow-[0px_-7px_100px_-50px_#ffaddd] shadow-2xl border-t border-l border-r border-gray-200 rounded-t-3xl z-10" />
		</div>
	</div>
	<Footer/>
</Layout>
