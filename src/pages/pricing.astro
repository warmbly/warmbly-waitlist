---
import Layout from "../layouts/Layout.astro";
import Header from '../components/Header/Header.astro';
import Footer from "../components/Footer/Footer.astro";
import Card from "../components/Pricing/Card.astro";
import Feature from "../components/Pricing/Feature.astro";
import Title from "../components/Pricing/Title.astro";
import Price from "../components/Pricing/Price.astro";
import CardTop from "../components/Pricing/CardTop.astro";
import CardIcon from "../components/Pricing/CardIcon.astro";

const starter = {
    monthly: 29,
    annually: 23
}
const grow = {
    monthly: 89,
    annually: 71,
}
const business = {
    monthly: 329,
    annually: 263
}

const title = "Plans & Pricing"
const description = "Choose a pricing plan that suits your needs. Whatever you pick, the Warmbly team is here to support you via email or Discord to help your business grow."
---

<Layout {title} {description}>
    <Header/>
    <div class="pt-40 pb-45 relative">
        <div class="absolute left-0 top-0 w-full h-full bg-linear-to-b from-transparent to-blue-500/50"></div>
        <div class="absolute inset-0">
            <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:14px_24px]"></div>
        </div>
        <div class="flex flex-col items-center">
            <h1 class="text-center text-5xl font-semibold mb-13">Our Pricing</h1>
            <p class="text-gray-600 max-w-4xl text-center px-4">Whichever plan you choose, you’re never on your own — we’re here to support you every step of the way. Whether it’s via our Discord server or by email, you’ll always have a team ready to help.</p>
            <div class="mt-10 flex items-center justify-center">
              <label class="relative inline-block">
                <input id="billing-toggle" type="checkbox" checked class="sr-only peer" />
                <div class="dot absolute left-1 peer-checked:left-29 top-1 bg-slate-200 w-28 peer-checked:w-48 h-12 rounded-full transition-all"></div>
                <div class="w-78 h-14 p-1 rounded-full bg-gray-50 transition shadow-md flex">
                    <div class="flex items-center justify-center h-12 w-28 z-1 cursor-pointer font-medium">Monthly</div>
                    <div class="flex items-center justify-center h-12 w-48 z-1 cursor-pointer gap-3 font-medium whitespace-nowrap">Annually <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-blue-500">20% OFF</span></div>
                </div>
              </label>
            </div>
        </div>
    </div>
    <div class="px-4 lg:grid-cols-4">
        <div class="max-w-7xl mx-auto">
            <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                <Card monthly={starter.monthly} annually={starter.annually}>
                    <CardTop>
                        <Title>Starter</Title>
                        <CardIcon className="bg-green-200 text-green-800">
                            <i class="ri-megaphone-line"></i>
                        </CardIcon>
                    </CardTop>
                    <Price monthly={starter.monthly} annually={starter.annually}>{starter.annually}</Price>
                    <p class="text-gray-500">Great for small businesses who have small budget.</p>
                    <hr class="text-gray-300 my-7"/>
                    <div class="grid gap-4">
                        <Feature>Unlimited Warmup</Feature>
                        <Feature>Unlimited MailBoxes</Feature>
                        <Feature>150 email/day</Feature>
                    </div>
                </Card>
                <Card monthly={grow.monthly} annually={grow.annually}>
                    <CardTop>
                        <Title>Grow</Title>
                        <CardIcon className="bg-orange-200 text-orange-800">
                            <i class="ri-bar-chart-2-line"></i>
                        </CardIcon>
                    </CardTop>
                    <Price monthly={grow.monthly} annually={grow.annually}>{grow.annually}</Price>
                    <p class="text-gray-500">Ideal for growing businesses looking to scale their outreach.</p>
                    <hr class="text-gray-300 my-7"/>
                    <div class="grid gap-4">
                        <Feature>Unlimited Warmup</Feature>
                        <Feature>Unlimited MailBoxes</Feature>
                        <Feature>3,000 email/day</Feature>
                    </div>
                </Card>
                <Card monthly={business.monthly} annually={business.annually} className="border-3 relative border-blue-500">
                    <CardTop>
                        <Title>Business</Title>
                        <CardIcon className="bg-indigo-200 text-indigo-800">
                            <i class="ri-at-line"></i>
                        </CardIcon>
                    </CardTop>
                    <Price monthly="329" annually="263">263</Price>
                    <p class="text-gray-500">Perfect for established teams that need advanced features and higher limits.</p>
                    <hr class="text-gray-300 my-7"/>
                    <div class="grid gap-4">
                        <Feature>Unlimited Warmup</Feature>
                        <Feature>Unlimited MailBoxes</Feature>
                        <Feature>15,000 email/day</Feature>
                        <Feature>Dedicated IPs</Feature>
                    </div>
                    <div class="absolute left-[50%] -translate-x-[50%] whitespace-nowrap px-4 text-white bg-blue-500 -top-5 rounded-full py-1 text-md">
                        Most Popular <i class="ri-bubble-chart-line"></i>
                    </div>
                </Card>
                <Card monthly="???" annually="???">
                    <CardTop>
                        <Title>Enterprise</Title>
                        <CardIcon className="bg-linear-to-r from-blue-200 to-purple-200 text-blue-800">
                            <i class="ri-medal-2-line"></i>
                        </CardIcon>
                    </CardTop>
                    <Price custom={true} monthly="Custom" annually="Custom"><span>Custom</span></Price>
                    <p class="text-gray-500">Designed for large organizations with custom needs and dedicated support.</p>
                    <hr class="text-gray-300 my-7"/>
                    <div class="grid gap-4">
                        <Feature>Unlimited Warmup</Feature>
                        <Feature>Unlimited MailBoxes</Feature>
                        <Feature>15,000+ email/day</Feature>
                        <Feature>Dedicated IPs</Feature>
                    </div>
                </Card>
            </div>
        </div>
    </div>
    <Footer/>
    <script>
        const toggle = document.getElementById("billing-toggle");
        const prices = document.querySelectorAll(".price");

        function updatePrices(isAnnual: boolean) {
        prices.forEach((price) => {
            const monthly = price.getAttribute("data-monthly");
            const annual = price.getAttribute("data-annually");
            if (isAnnual) {
                price.textContent = annual;
            } else {
                price.textContent = monthly;
            }
        });
        }

        updatePrices(true);

        if (toggle) toggle.addEventListener("change", (e) => {
            const target = e.target as HTMLInputElement | null;
            if (!target) return;
            updatePrices(target.checked);
        });
    </script>
</Layout>