---
import Layout from '../layouts/Layout.astro';

const title = "Warmbly | Open Source AI Email Warmup & Outreach"
const description = "Warmbly is an open source, AI-powered email warmup and outreach platform that builds your sender reputation and keeps you out of spam. Join the waitlist for early access."

const KIT_FORM_ID = "9115146";
---

<Layout {title} {description}>
  <main class="relative">

    <!-- ════════════ Sky atmosphere (fixed, full-bleed, clipped) ════════════
         Mirrors site/HeroAtmosphere.astro + web auth layout: deep-sky gradient,
         breathing glow, drifting cloud WebPs, soft pulsing sun. Pinned to the
         viewport so the clouds never add scroll and the card can float over it. -->
    <div class="fixed inset-0 overflow-hidden" aria-hidden="true">
      <div class="sky-base"></div>
      <div class="sky-breathe"></div>
      <div class="sky-haze-bottom"></div>
      <div class="sun-glow"></div>

      <!-- Real painterly clouds — framed around the edges so the centered card
           stays clear. Front clouds are larger/more opaque; the two hero clouds
           load eagerly, the rest lazily. -->
      <img
        src="/backdrops/cloud-5.webp" alt="" decoding="async"
        loading="eager" fetchpriority="high"
        class="cloud-drift cloud-1"
        style="top: -6%; left: -8%; width: clamp(300px, 44vw, 660px); opacity: 0.92;"
      />
      <img
        src="/backdrops/cloud-2.webp" alt="" decoding="async"
        loading="eager" fetchpriority="high"
        class="cloud-drift cloud-2"
        style="top: 0%; right: -7%; width: clamp(280px, 40vw, 600px); opacity: 0.88;"
      />
      <img
        src="/backdrops/cloud-3.webp" alt="" decoding="async" loading="lazy"
        class="cloud-drift cloud-3"
        style="top: 46%; left: -12%; width: clamp(220px, 28vw, 440px); opacity: 0.68;"
      />
      <img
        src="/backdrops/cloud-4.webp" alt="" decoding="async" loading="lazy"
        class="cloud-drift cloud-1"
        style="bottom: 3%; right: -7%; width: clamp(220px, 28vw, 430px); opacity: 0.64;"
      />
      <img
        src="/backdrops/cloud-1.webp" alt="" decoding="async" loading="lazy"
        class="cloud-drift cloud-2"
        style="bottom: -7%; left: 15%; width: clamp(180px, 24vw, 380px); opacity: 0.48;"
      />

      <!-- Twinkling spark -->
      <svg
        class="absolute pointer-events-none animate-pulse-soft"
        style="top: 15%; left: 33%; width: 14px; height: 14px;"
        viewBox="0 0 14 14" fill="none"
      >
        <path d="M7 1 L8.5 5.5 L13 7 L8.5 8.5 L7 13 L5.5 8.5 L1 7 L5.5 5.5 Z" fill="rgba(255,255,255,0.9)" />
      </svg>

      <!-- Soft veil so the white logo + footer stay legible over the clouds -->
      <div class="content-veil"></div>
    </div>

    <!-- ════════════ Content ════════════ -->
    <div class="relative z-10 flex min-h-[100dvh] w-full flex-col items-center justify-center px-5 py-12">

      <!-- Logo — white, on the sky, above the card -->
      <a href="https://warmbly.com" class="animate-fade-in-up mb-6 flex items-center gap-2.5">
        <svg class="w-8 h-8" viewBox="0 0 746 764" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M222.805 644.772L186.274 108.881L704.5 451.158L484.5 451.158L245.5 196.158L444 463.5L222.805 644.772Z" fill="white" />
        </svg>
        <span class="font-extrabold text-[20px] tracking-tight text-white">Warmbly</span>
      </a>

      <!-- Card -->
      <div class="card-enter w-full max-w-[500px]">
        <div class="relative">
          <div class="card-glow" aria-hidden="true"></div>

          <div class="relative overflow-hidden rounded-[28px] border border-slate-200 bg-white px-6 py-9 text-center shadow-[0_1px_2px_rgba(15,23,42,0.05),0_44px_80px_-34px_rgba(8,47,73,0.42)] sm:px-9 sm:py-10">
            <!-- top sky accent line -->
            <div class="pointer-events-none absolute inset-x-8 top-0 h-px bg-gradient-to-r from-transparent via-sky-400/70 to-transparent"></div>

            <!-- Eyebrow / open-source pill -->
            <a
              href="https://github.com/warmbly/warmbly" target="_blank" rel="noopener noreferrer"
              class="reveal-1 mb-6 inline-flex h-8 items-center gap-1.5 rounded-full border border-slate-200 bg-slate-50 pl-2.5 pr-3 text-[11.5px] font-medium text-slate-600 transition-colors hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700"
            >
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.8 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.9.1 3.1.8.8 1.2 1.9 1.2 3.2 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.5 4.6-1.5 7.8-5.8 7.8-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
              Open source · Join the waitlist
            </a>

            <!-- Heading — Fraunces display serif -->
            <h1
              class="reveal-2 text-[27px] leading-[1.06] text-slate-900 sm:text-[38px]"
              style="font-family: 'Fraunces Variable', Georgia, 'Times New Roman', serif; font-weight: 560; font-optical-sizing: auto; letter-spacing: -0.02em;"
            >
              Your emails deserve<br/>
              the <span class="italic text-sky-600">inbox.</span>
            </h1>

            <!-- Subtitle -->
            <p class="reveal-3 mx-auto mt-3.5 max-w-[330px] text-[14px] leading-relaxed text-slate-500">
              Open-source, AI email warmup &amp; outreach that builds sender reputation and keeps you out of spam. Be first when we launch.
            </p>

            <!-- Waitlist form -->
            <div data-waitlist-root class="reveal-4 relative mt-7 flex min-h-[106px] w-full items-center justify-center">
              <form
                data-waitlist-form
                data-form-id={KIT_FORM_ID}
                class="flex w-full flex-col gap-2.5 transition-all duration-300"
              >
                <input
                  type="email"
                  name="email"
                  placeholder="you@example.com"
                  required
                  class="h-12 w-full rounded-xl border border-slate-200 bg-white px-4 text-[14.5px] text-slate-900 placeholder:text-slate-400 outline-none transition-all duration-200 focus:border-sky-400 focus:ring-4 focus:ring-sky-400/15"
                />
                <p data-waitlist-error class="pl-1 text-left text-[12px] leading-4 text-rose-500 empty:hidden"></p>
                <button
                  type="submit"
                  data-waitlist-btn
                  class="group relative flex h-12 w-full cursor-pointer items-center justify-center overflow-hidden rounded-xl bg-gradient-to-b from-sky-500 to-sky-600 text-[14.5px] font-semibold text-white ring-1 ring-inset ring-white/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.35),0_1px_2px_rgba(2,132,199,0.25),0_10px_22px_-8px_rgba(2,132,199,0.55)] transition-[transform,box-shadow,filter] duration-200 hover:-translate-y-0.5 hover:brightness-[1.05] hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.4),0_1px_2px_rgba(2,132,199,0.25),0_16px_32px_-8px_rgba(2,132,199,0.7)] active:translate-y-0 active:brightness-95"
                >
                  <span data-btn-text class="inline-flex items-center justify-center gap-2 transition-all duration-200">
                    Join the waitlist
                    <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                  </span>
                  <span data-btn-spinner class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-200">
                    <svg class="w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
                      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2.5" opacity="0.3"></circle>
                      <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>
                    </svg>
                  </span>
                </button>
              </form>

              <!-- Success state -->
              <div data-waitlist-success class="pointer-events-none absolute flex w-full scale-95 items-center justify-center gap-3 opacity-0 transition-all duration-400">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-emerald-200 bg-emerald-50">
                  <svg class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                    <path data-check-path d="M20 6L9 17l-5-5" style="stroke-dasharray: 30; stroke-dashoffset: 30; transition: stroke-dashoffset 0.4s ease 0.2s;" />
                  </svg>
                </div>
                <div class="text-left">
                  <p class="text-[14px] font-semibold text-slate-900">You're on the list!</p>
                  <p class="text-[12.5px] text-slate-500">We'll email you when we launch.</p>
                </div>
              </div>
            </div>

            <p class="reveal-5 mt-3.5 text-[11.5px] text-slate-500">No spam. Unsubscribe anytime.</p>
          </div>
        </div>
      </div>

      <!-- Footer — on the sky, below the card -->
      <div class="animate-fade-in mt-8 flex flex-col items-center gap-2.5">
        <div class="flex items-center gap-4">
          <a href="https://github.com/warmbly/warmbly" target="_blank" rel="noopener noreferrer" class="text-[12px] text-white/50 transition-colors hover:text-white/80">GitHub</a>
          <span class="text-white/25">·</span>
          <a href="https://dc.warmbly.com" target="_blank" rel="noopener noreferrer" class="text-[12px] text-white/50 transition-colors hover:text-white/80">Discord</a>
          <span class="text-white/25">·</span>
          <a href="https://x.warmbly.com" target="_blank" rel="noopener noreferrer" class="text-[12px] text-white/50 transition-colors hover:text-white/80">X</a>
        </div>
        <div class="flex items-center gap-2.5">
          <a href="/terms" class="text-[11px] text-white/40 transition-colors hover:text-white/70">Terms</a>
          <span class="text-white/20">·</span>
          <a href="/privacy" class="text-[11px] text-white/40 transition-colors hover:text-white/70">Privacy</a>
          <span class="text-white/20">·</span>
          <span class="text-[11px] text-white/35">&copy; {new Date().getFullYear()} Mindroot Ltd</span>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  function initWaitlistForms() {
    document.querySelectorAll('[data-waitlist-root]').forEach((root) => {
      const el = root as HTMLElement;
      if (el.dataset.initialized) return;
      el.dataset.initialized = 'true';

      const form = el.querySelector('[data-waitlist-form]') as HTMLFormElement;
      const input = form.querySelector('input[name="email"]') as HTMLInputElement;
      const btn = form.querySelector('[data-waitlist-btn]') as HTMLButtonElement;
      const btnText = btn.querySelector('[data-btn-text]') as HTMLElement;
      const btnSpinner = btn.querySelector('[data-btn-spinner]') as HTMLElement;
      const errorEl = form.querySelector('[data-waitlist-error]') as HTMLElement;
      const successEl = el.querySelector('[data-waitlist-success]') as HTMLElement;
      const checkPath = successEl.querySelector('[data-check-path]') as SVGPathElement;

      function showError(msg: string) {
        // Setting textContent un-hides the row (`empty:hidden`); clearing it
        // collapses the row again so the input + button stay tight together.
        errorEl.textContent = msg;
        input.style.borderColor = 'rgba(244, 63, 94, 0.6)';
        setTimeout(() => {
          errorEl.textContent = '';
          input.style.borderColor = '';
        }, 3000);
      }

      function setLoading(loading: boolean) {
        btn.disabled = loading;
        if (loading) {
          btnText.style.opacity = '0';
          btnText.style.transform = 'translateY(4px)';
          btnSpinner.style.opacity = '1';
          btn.style.pointerEvents = 'none';
        } else {
          btnText.style.opacity = '1';
          btnText.style.transform = 'translateY(0)';
          btnSpinner.style.opacity = '0';
          btn.style.pointerEvents = '';
        }
      }

      function showSuccess() {
        form.style.opacity = '0';
        form.style.transform = 'translateY(-8px)';
        form.style.pointerEvents = 'none';

        setTimeout(() => {
          form.style.position = 'absolute';
          successEl.style.position = 'relative';
          successEl.style.opacity = '1';
          successEl.style.transform = 'scale(1)';
          successEl.style.pointerEvents = 'auto';
          checkPath.style.strokeDashoffset = '0';
        }, 300);

        setTimeout(() => {
          successEl.style.opacity = '0';
          successEl.style.transform = 'scale(0.95)';
          successEl.style.pointerEvents = 'none';

          setTimeout(() => {
            successEl.style.position = 'absolute';
            form.style.position = 'relative';
            form.style.opacity = '1';
            form.style.transform = 'translateY(0)';
            form.style.pointerEvents = '';
            setLoading(false);
            input.value = '';
            checkPath.style.strokeDashoffset = '30';
          }, 300);
        }, 5000);
      }

      input.addEventListener('input', () => {
        errorEl.textContent = '';
        input.style.borderColor = '';
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formId = form.dataset.formId;
        const email = input.value.trim();

        if (!email) {
          showError('Please enter your email');
          input.focus();
          return;
        }

        setLoading(true);
        errorEl.textContent = '';

        try {
          const res = await fetch(
            `https://app.kit.com/forms/${formId}/subscriptions`,
            {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json',
              },
              body: JSON.stringify({ email_address: email }),
            }
          );

          const data = await res.json().catch(() => null);

          if (res.ok && data?.status === 'success') {
            showSuccess();
          } else {
            throw new Error(data?.error || 'Request failed');
          }
        } catch (err: any) {
          setLoading(false);
          showError(err?.message === 'Failed to fetch'
            ? 'Network error. Check your connection.'
            : 'Something went wrong. Try again.');
          btn.style.animation = 'shake 0.4s ease';
          setTimeout(() => btn.style.animation = '', 400);
        }
      });
    });
  }

  initWaitlistForms();
  document.addEventListener('astro:after-swap', initWaitlistForms);
</script>
