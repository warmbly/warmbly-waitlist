---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header/Header.astro';
import Heropic from '../components/Heropic.astro';
import Box from '../components/Section2/Box.astro';
import Icon from '../components/Section2/Icon.astro';
import BoxTop from '../components/Section2/BoxTop.astro';
import BoxStep from '../components/Section2/BoxStep.astro';
import BoxTitle from "../components/Section2/BoxTitle.astro";
import BoxDescription from "../components/Section2/BoxDescription.astro";
import Footer from "../components/Footer/Footer.astro";

title: "Warmbly | Scale Your Email Outreach with AI"
description: "Warmbly | Scale Your Email Outreach with AI"
---

<Layout>
	<Header/>
	<div class="px-4 bg-gray-50 overflow-hidden">
		<div class="max-w-7xl mx-auto">
			<div class="flex flex-col items-center">
				<div class="py-2 px-3 mt-20 text-gray-500"><span class="bg-linear-to-r from-cyan-500 to-blue-600 text-white py-1 px-3 rounded-lg mr-3">AI</span> Powered Personalization</div>
				<h1 class="font-bold text-5xl text-center text-gray-800 mb-13 max-w-5xl mt-10 leading-13">Helping You Grow Your Business and Scale Your Email Outreach with AI</h1>
				<p class="text-center max-w-6xl text-gray-500 text-md">Warmbly makes it easy to launch cold email campaigns that feel truly personal and human. Build trust, save time and create meaningful connections with AI that works for you — so you can focus on nurturing relationships and growing your business.</p>
			</div>
			<div class="mt-15 flex justify-center items-center gap-7">
				<a href="https://app.warmbly.com/" class="px-5 py-3 bg-blue-500 transition hover:bg-blue-600 text-gray-50 rounded-full">Get started for free</a>
				<p class="text-gray-500">No credit card required.</p>
			</div>
			<Heropic className="w-full mt-20 shadow-[0px_-7px_100px_-50px_#ffaddd] shadow-2xl border-t border-l border-r border-gray-200 rounded-t-3xl z-10" />
		</div>
	</div>
	<section class="py-25 px-4 bg-white">
		<div class="max-w-7xl mx-auto">
			<div class="flex gap-15">
				<div class="max-w-lg">
					<p class="uppercase text-blue-500 mb-5">Choose the easier way</p>
					<h1 class="text-5xl font-bold text-gray-800 mb-8 leading-14">Sending Emails Has Never Been Easier.</h1>
				</div>
				<p class="text-gray-500 max-w-4xl mt-12 text-lg">Connect, create, and let Warmbly do the rest. No more manual sending, no more wasted hours. Warmbly prepares, warms up, and delivers your emails, so you can focus on growing your business.</p>
			</div>
			<div class="grid grid-cols-3 gap-10 mt-10">
				<Box>
					<BoxTop className="text-indigo-700">
						<Icon className="bg-indigo-200">
							<i class="ri-mail-ai-line"></i>
						</Icon>
						<BoxStep>1</BoxStep>
					</BoxTop>
					<BoxTitle>Connect Your Email Addresses</BoxTitle>
					<BoxDescription>Link your existing addresses.</BoxDescription>
				</Box>
				<Box>
					<BoxTop className="text-orange-700">
						<Icon className="bg-orange-200">
							<i class="ri-megaphone-line"></i>
						</Icon>
						<BoxStep>2</BoxStep>
					</BoxTop>
					<BoxTitle>Create a Campaign</BoxTitle>
					<BoxDescription>Build your templates, set the schedule.</BoxDescription>
				</Box>
				<Box>
					<BoxTop className="text-green-700">
						<Icon className="bg-green-200">
							<i class="ri-group-line"></i>
						</Icon>
						<BoxStep>3</BoxStep>
					</BoxTop>
					<BoxTitle>Import Your Contacts</BoxTitle>
					<BoxDescription>Upload your leads, customers, or prospects.</BoxDescription>
				</Box>
				<Box className="md:col-span-2">
					<BoxTop className="text-amber-700">
						<Icon className="bg-amber-200">
							<i class="ri-flashlight-line"></i>
						</Icon>
						<BoxStep>4</BoxStep>
					</BoxTop>
					<BoxTitle>Warmbly Does the Rest For You</BoxTitle>
					<BoxDescription>It automatically sends your campaign at the right time, while warming up your accounts for better deliverability.</BoxDescription>
				</Box>
			</div>
		</div>
	</section>
	<Footer/>
</Layout>
