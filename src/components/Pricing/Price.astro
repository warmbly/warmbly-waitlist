---
const { annually, monthly, custom } = Astro.props;
---

<p class="text-xl text-gray-800 mb-5"><b>{!custom && "$"}<span class={`price ${custom && "text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-blue-500"}`} data-monthly={monthly} data-annually={annually}><slot/></span></b><span class="text-sm"> {!custom && "/ month"}</span></p>