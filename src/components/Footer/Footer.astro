---
import FooterTitle from "./FooterTitle.astro";
import Logo from '..//Logo.astro';
import FooterLink from './FooterLink.astro';
import FooterSocial from "./FooterSocial.astro";
---

<footer class="px-4 py-15 bg-slate-50">
    <div class="max-w-7xl mx-auto">
		<div class="flex gap-20 justify-between">
			<div>
				<h1 class="text-gray-700 text-4xl font-medium max-w-3xl leading-13">Are You Ready to Let Warmbly Handle Your Email Outreach?</h1>
			</div>
			<div class="flex justify-start gap-5 items-center">
				<a href="https://app.warmbly.com/auth/register" class="px-4 py-2 border-2 text-blue-500 border-blue-500 rounded-full whitespace-nowrap transition hover:brightness-90">Sign Up</a>
				<a href="https://app.warmbly.com" class="px-4 py-2 bg-blue-500 rounded-full text-white whitespace-nowrap transition hover:brightness-95">Go to the App</a>
			</div>
		</div>
		<hr class="text-gray-200 my-15">
		<div class="flex py-3 gap-10">
			<div>
				<div class="flex items-center gap-8 ml-0.5">
					<Logo className="w-11"/>
					<h1 class="font-semibold text-gray-700 text-2xl -mb-2">Warmbly.</h1>
				</div>
                <p class="mt-10 text-gray-500 leading-7"><span id="year"></span> &copy; Warmbly.com. All Right Reserved.<br/>Send Emails at Scale, Automatically.</p>
                <script>
                    const obj = document.getElementById('year');
                    if (obj) obj.textContent = new Date().getFullYear().toString();
                </script>
                <div class="flex gap-5 mt-8">
                    <FooterSocial href="https://dc.warmbly.com">
                        <i class="ri-discord-fill"></i>
                    </FooterSocial>
                    <FooterSocial href="https://x.warmbly.com">
                        <i class="ri-twitter-x-line"></i>
                    </FooterSocial>
                    <FooterSocial href="https://ig.warmbly.com">
                        <i class="ri-instagram-line"></i>
                    </FooterSocial>
                    <FooterSocial href="https://yt.warmbly.com">
                        <i class="ri-youtube-fill"></i>
                    </FooterSocial>
                </div>
			</div>
			<div class="grid gap-20 md:grid-cols-2 lg:grid-cols-3 ml-auto">
				<div>
					<FooterTitle>Product / Features</FooterTitle>
					<FooterLink>Pricing</FooterLink>
					<FooterLink>Blog</FooterLink>
					<FooterLink>API & Intergrations</FooterLink>
					<FooterLink>Email Warmup</FooterLink>
				</div>
				<div>
					<FooterTitle>Resources</FooterTitle>
					<FooterLink>Discord Community</FooterLink>
				</div>
				<div>
					<FooterTitle>Company</FooterTitle>
					<FooterLink>Terms of Service</FooterLink>
					<FooterLink>Privacy Policy</FooterLink>
				</div>
			</div>
		</div>
    </div>
</footer>